{
  "name": "mcp-tfs2018",
  "version": "1.3.0",
  "description": "MCP Server for Microsoft Team Foundation Server 2018",
  "main": "dist/index.js",
  "scripts": {
    "build": "node scripts/build.mjs",
    "update": "node scripts/update.mjs",
    "dev": "ts-node src/index.ts",
    "start": "node scripts/launcher.mjs",
    "setup": "npm run build && node dist/setup.js",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "node --max-old-space-size=12288 ./node_modules/typescript/bin/tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "mcp",
    "tfs",
    "tfs2018",
    "team-foundation-server",
    "azure-devops"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "adm-zip": "^0.5.16",
    "axios": "^1.7.7",
    "axios-ntlm": "^1.3.1",
    "dotenv": "^16.4.5",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "kerberos": "^2.1.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.5",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.11.1",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ]
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "kerberos@2.2.2": true
  }
}
