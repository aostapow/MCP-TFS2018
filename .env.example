# ============================================================
# MCP TFS 2018 Server - Configuracion
# ============================================================
# Copia este archivo a .env y completa los valores.
# NUNCA incluyas .env en control de versiones.

# --- Conexion TFS ---
# URL base del servidor TFS (sin barra al final)
TFS_BASE_URL=http://tu-servidor-tfs:8080/tfs

# Collection
TFS_COLLECTION=DefaultCollection

# Proyecto TFS por defecto (las tools pueden recibir otro proyecto por llamada)
TFS_PROJECT=MiProyecto

# Version de la REST API (TFS 2018 soporta 1.0 a 4.1; recomendado 4.1)
TFS_API_VERSION=4.1

# Timeout de requests HTTP en milisegundos
TFS_TIMEOUT_MS=30000

# Maximos items por pagina en listados
TFS_MAX_PAGE_SIZE=200


# --- Autenticacion ---
# Tipo: ntlm | basic | pat | kerberos
TFS_AUTH_TYPE=pat

# Para PAT (Personal Access Token)
TFS_PAT=tu-personal-access-token

# Para NTLM y Basic (descomentar si usas estos)
# TFS_USERNAME=DOMINIO\usuario
# TFS_PASSWORD=tu-password
# TFS_DOMAIN=DOMINIO


# --- Red ---
# Validar certificados TLS (false = aceptar autofirmados)
# Solo desactivar en redes internas de confianza
TFS_TLS_REJECT_UNAUTHORIZED=false

# Proxy corporativo (opcional)
# TFS_PROXY_URL=http://proxy.empresa.com:8080


# --- Servidor MCP ---
# Tipo de transporte: stdio (para Claude Desktop / Cursor) | http
MCP_TRANSPORT=stdio
MCP_PORT=3000

# Chequeo de actualizaciones al arrancar (consulta GitHub Releases)
# Poner false para desactivar el aviso en logs
MCP_TFS_UPDATE_CHECK=true

# Auto-actualizar desde el zip del release antes de arrancar (requiere scripts/launcher.mjs)
MCP_TFS_AUTO_UPDATE=true

# URL alternativa para chequeo de releases (mirror interno o endpoint custom)
# MCP_TFS_UPDATE_URL=https://api.github.com/repos/aostapow/MCP-TFS2018/releases/latest


# --- Logging ---
# Nivel: error | warn | info | debug
LOG_LEVEL=info
# Formato: pretty (desarrollo) | json (produccion)
# Los logs salen por stderr (stdout queda libre para el protocolo JSON-RPC)
LOG_FORMAT=pretty
